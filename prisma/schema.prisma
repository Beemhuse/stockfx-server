// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String          @id @default(uuid()) @db.Uuid
  email               String          @unique
  password_hash       String?
  name                String?
  phone               String?
  avatar_url          String?
  status              String?         @default("active")
  registration_status String?         @default("confirmed")
  is_verified         Boolean?        @default(false)
  is_admin            Boolean         @default(false)
  verification_token  String?         @unique
  created_at          DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?       @default(now()) @db.Timestamptz(6)
  
  account             UserAccount?
  devices             Device[]
  sessions            DeviceSession[]
  transactions        Transaction[]
  portfolio           Portfolio[]
  session_events      SessionEvent[]

  @@map("users")
}

model OtpCode {
  id         BigInt    @id @default(autoincrement())
  email      String
  code       String
  expires_at DateTime  @db.Timestamptz(6)
  verified   Boolean?  @default(false)
  attempts   Int?      @default(0)
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  @@index([email, verified], map: "idx_otp_email_verified")
  @@map("otp_codes")
}

model Device {
  id          String    @id @default(uuid()) @db.Uuid
  user_id     String    @db.Uuid
  device_id   String
  device_name String?
  device_type String?   // 'web', 'mobile', 'desktop'
  browser     String?
  os          String?
  ip_address  String?
  last_active DateTime? @default(now()) @db.Timestamptz(6)
  is_active   Boolean?  @default(true)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)

  user           User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  sessions       DeviceSession[]
  session_events SessionEvent[]

  @@unique([user_id, device_id])
  @@map("devices")
}

model DeviceSession {
  id         String   @id @default(uuid()) @db.Uuid
  device_id  String   @db.Uuid
  user_id    String   @db.Uuid
  token      String
  expires_at DateTime @db.Timestamptz(6)
  is_active  Boolean? @default(true)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)

  device Device @relation(fields: [device_id], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("device_sessions")
}

model UserAccount {
  id               String    @id @default(uuid()) @db.Uuid
  user_id          String    @unique @db.Uuid
  balance          Float?    @default(0)
  total_investment Float?    @default(0)
  account_number   String?
  account_type     String?   @default("standard")
  kyc_status       String?   @default("pending")
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  updated_at       DateTime? @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_accounts")
}

model Transaction {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  type       String?   // 'buy', 'sell', 'deposit', 'withdrawal'
  symbol     String?
  quantity   Float?
  price      Float?
  amount     Float?
  status     String?   @default("completed")
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Portfolio {
  id           String    @id @default(uuid()) @db.Uuid
  user_id      String    @db.Uuid
  symbol       String
  quantity     Float
  average_cost Float?
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  updated_at   DateTime? @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, symbol])
  @@map("portfolio")
}

model SessionEvent {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  device_id  String?   @db.Uuid
  event_type String    // 'login', 'logout', 'session_update', 'device_removed'
  event_data Json?
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  user   User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  device Device? @relation(fields: [device_id], references: [id], onDelete: SetNull)

  @@map("session_events")
}
